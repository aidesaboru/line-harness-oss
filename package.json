{
  "name": "line-oss-crm",
  "version": "0.15.0",
  "private": true,
  "description": "Open-source LINE Official Account CRM/marketing automation",
  "scripts": {
    "dev:worker": "corepack pnpm --filter worker dev",
    "dev:web": "corepack pnpm --filter web dev",
    "build": "test -n \"$NEXT_PUBLIC_API_URL\" || (echo \"NEXT_PUBLIC_API_URL is required for build\" >&2; exit 1); corepack pnpm -r build",
    "sandbox:create-line-harness": "bash scripts/run-create-line-harness-sandbox.sh",
    "deploy:worker": "tsx scripts/production-deploy.ts",
    "deploy:web": "corepack pnpm --filter web build",
    "db:migrate": "wrangler d1 execute line-crm --file=packages/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute line-crm --file=packages/db/schema.sql --local",
    "deploy:setup": "node packages/create-line-harness/dist/index.js",
    "deploy:update": "node packages/create-line-harness/dist/index.js update",
    "support-crm:fixtures": "tsx scripts/support-crm-fixture-candidates.ts --run",
    "support-crm:fixtures:sql": "tsx scripts/support-crm-fixture-candidates.ts --print-sql",
    "support-crm:fixtures:seed": "tsx scripts/support-crm-seed-fixtures.ts --run",
    "support-crm:fixtures:seed-sql": "tsx scripts/support-crm-seed-fixtures.ts --print-sql",
    "support-crm:fixtures:cleanup": "tsx scripts/support-crm-seed-fixtures.ts --cleanup",
    "support-crm:fixtures:cleanup-sql": "tsx scripts/support-crm-seed-fixtures.ts --cleanup-sql",
    "support-crm:fixtures:verify-cleanup": "tsx scripts/support-crm-seed-fixtures.ts --verify-cleanup",
    "support-crm:fixtures:verify-cleanup-sql": "tsx scripts/support-crm-seed-fixtures.ts --verify-cleanup-sql",
    "preflight:support-crm": "tsx scripts/support-crm-preflight.ts",
    "preflight:support-crm:dry-run": "tsx scripts/support-crm-preflight.ts --dry-run",
    "preflight:support-crm:summary": "tsx scripts/support-crm-preflight-summary.ts",
    "support-crm:release-readiness": "tsx scripts/support-crm-release-readiness.ts",
    "test:scripts": "vitest run --config vitest.config.ts",
    "build:bundle": "tsx scripts/release/build-bundle.ts"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0",
    "wrangler": "4"
  }
}
